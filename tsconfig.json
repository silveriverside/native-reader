{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "react-native-math-view/src/fallback": ["src/types/react-native-math-view.d.ts"]
    },
    "ignoreDeprecations": "6.0",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "exclude": ["node_modules", "**/__tests__/*", "jest.config.js", "jest.setup.js"]
}
